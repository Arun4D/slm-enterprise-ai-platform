# FastAPI
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8001"]

# SLM Model Configuration
SLM_MODEL_PATH=/models/qwen2.5-1.5b-instruct-gguf/model.gguf
SLM_MODEL_CONTEXT_SIZE=2048
SLM_MODEL_THREADS=4
SLM_MODEL_GPU_LAYERS=0

# Security
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Plugin System
PLUGIN_AUTO_DISCOVERY=true
PLUGIN_ALLOWED_PATHS=["/agents","/plugins"]
PLUGIN_TRUSTED_SOURCES=internal
EXTRA_ALLOWED_PATHS=[]

# Audit
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_PATH=/logs/audit

# Agent Constraints
AGENT_EXECUTION_TIMEOUT_SECONDS=300
AGENT_MEMORY_LIMIT_MB=512
