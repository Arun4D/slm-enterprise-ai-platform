# Windows development environment template.
# Copy to backend/.env and edit local paths/secrets as needed.

# FastAPI
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8001"]

# SLM Model Configuration
SLM_ENABLED=true
# Prefer forward slashes in .env on Windows.
SLM_MODEL_PATH=C:/arun/workspace/qwen2.5-1.5b-instruct-gguf/model.gguf
SLM_MODEL_CONTEXT_SIZE=2048
SLM_MODEL_THREADS=4
SLM_MODEL_GPU_LAYERS=0

# Security
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Plugin System
PLUGIN_AUTO_DISCOVERY=true
PLUGIN_ALLOWED_PATHS=["C:/arun/workspace/slm-enterprise-ai-platform/agents","C:/arun/workspace/slm-enterprise-ai-platform/plugins"]
PLUGIN_TRUSTED_SOURCES=internal
RUNTIME_WORKSPACE_PATH=C:/temp/slm-enterprise-ai-platform
EXTRA_ALLOWED_PATHS=["C:/arun/workspace","C:/temp/slm-enterprise-ai-platform"]

# Audit
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_PATH=logs/audit

# Agent Constraints
AGENT_EXECUTION_TIMEOUT_SECONDS=300
AGENT_MEMORY_LIMIT_MB=512
