# Linux development environment template.
# Copy to backend/.env and edit local paths/secrets as needed.

# FastAPI
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8001"]

# SLM Model Configuration
SLM_ENABLED=true
SLM_MODEL_PATH=/home/arun/Workspace/slm-models/phi-3-mini-gguf/model.gguf
SLM_MODEL_CONTEXT_SIZE=2048
SLM_MODEL_THREADS=4
SLM_MODEL_GPU_LAYERS=0

# Security
JWT_SECRET_KEY=change-this-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Plugin System
PLUGIN_AUTO_DISCOVERY=true
PLUGIN_ALLOWED_PATHS=["/home/arun/Workspace/arun4d_github/slm-enterprise-ai-platform/agents","/home/arun/Workspace/arun4d_github/slm-enterprise-ai-platform/plugins"]
PLUGIN_TRUSTED_SOURCES=internal
RUNTIME_WORKSPACE_PATH=/tmp/slm-enterprise-ai-platform
EXTRA_ALLOWED_PATHS=["/home/arun/Workspace","/tmp/slm-enterprise-ai-platform"]

# Audit
AUDIT_LOGGING_ENABLED=true
AUDIT_LOG_PATH=logs/audit

# Agent Constraints
AGENT_EXECUTION_TIMEOUT_SECONDS=300
AGENT_MEMORY_LIMIT_MB=512
